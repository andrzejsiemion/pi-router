---
# Copy this file to secrets.yml, fill in values, then run:
#   ansible-playbook pi-router.yml -e @secrets.yml

# Twingate — generate tokens in Admin Console → Connectors → Add Connector → Linux
twingate_network: "your-network-name"
twingate_access_token: "your-access-token"
twingate_refresh_token: "your-refresh-token"

# Slack incoming webhook URL
slack_webhook_url: "https://hooks.slack.com/services/T.../B.../..."
